<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petty_reload_form" model="ir.ui.view">
        <field name="name">petty.reload.form</field>
        <field name="model">petty.reload</field>
        <field name="arch" type="xml">
            <form string="Recarga de Caja Menor">
                <header>
                    <button name="action_approve" string="Aprobar" type="object" states="draft" class="oe_highlight" groups="base.group_erp_manager"/>
                    <button name="action_execute" string="Marcar Realizada" type="object" states="approved" class="oe_highlight" groups="base.group_erp_manager"/>
                    <button name="action_cancel" string="Rechazar" type="object" states="draft,approved" groups="base.group_erp_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,executed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="employee_name"/>
                            <field name="card_number"/>
                        </group>
                        <group>
                            <field name="amount_requested"/>
                            <field name="date_request"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observaciones">
                            <field name="observations" placeholder="Indicar si es pérdida de tarjeta o recarga a terceros..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_petty_reload_tree" model="ir.ui.view">
        <field name="name">petty.reload.tree</field>
        <field name="model">petty.reload</field>
        <field name="arch" type="xml">
            <tree string="Recargas de Caja Menor" decoration-info="state == 'draft'" decoration-success="state == 'executed'">
                <field name="name"/>
                <field name="employee_name"/>
                <field name="amount_requested"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_petty_reload" model="ir.actions.act_window">
        <field name="name">Recargas de Caja Menor</field>
        <field name="res_model">petty.reload</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_petty_flow_root" name="PettyFlow" sequence="10"/>
    <menuitem id="menu_petty_reload" name="Solicitudes" parent="menu_petty_flow_root" action="action_petty_reload" sequence="10"/>
</odoo>
